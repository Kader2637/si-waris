generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Jenazah {
  id             String        @id @default(cuid())
  nama           String
  nik            String
  gender         String
  hartaKotor     Float         @default(0)
  utang          Float         @default(0)
  wasiat         Float         @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  hukum          String        @default("Islam")
  keterangan     String?
  potongGonoGini Boolean       @default(false)
  tanggalWafat   DateTime      @default(now())
  ahliWaris      AhliWaris[]
  hasilWaris     HasilWaris[]
  logKalkulasi   LogKalkulasi?
}

model AhliWaris {
  id          String      @id @default(cuid())
  jenazahId   String
  nama        String
  nik         String
  hubungan    String
  fileKtpKk   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  parentId    String?
  statusHidup Boolean     @default(true)
  jenazah     Jenazah     @relation(fields: [jenazahId], references: [id], onDelete: Cascade)
  parent      AhliWaris?  @relation("HeirSuccession", fields: [parentId], references: [id])
  children    AhliWaris[] @relation("HeirSuccession")
  hasil       HasilWaris?
}

model HasilWaris {
  id           String    @id @default(cuid())
  jenazahId    String
  ahliWarisId  String    @unique
  status       String
  alasan       String
  jatahPersen  String?
  jatahNominal Float     @default(0)
  createdAt    DateTime  @default(now())
  ahliWaris    AhliWaris @relation(fields: [ahliWarisId], references: [id], onDelete: Cascade)
  jenazah      Jenazah   @relation(fields: [jenazahId], references: [id], onDelete: Cascade)
}

model LogKalkulasi {
  id               String   @id @default(cuid())
  jenazahId        String   @unique
  kpk              Int?
  statusAulRadd    String?
  totalHartaBersih Float
  createdAt        DateTime @default(now())
  hartaGonoGini    Float?   @default(0)
  metodeAdat       String?
  jenazah          Jenazah  @relation(fields: [jenazahId], references: [id], onDelete: Cascade)
}
